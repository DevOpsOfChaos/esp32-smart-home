# SmartHome Server V1 - isolierte Test-only Simulation
# Nur fuer den Fake-Master-Harness auf lokalen Loopback-Ports.

TZ=Europe/Berlin

MQTT_BIND_ADDRESS=127.0.0.1
MQTT_HOST_PORT=18883
MQTT_HOST=mosquitto
MQTT_BASE_TOPIC=smarthome
MQTT_USERNAME=
MQTT_PASSWORD=

NODERED_BIND_ADDRESS=127.0.0.1
NODERED_HOST_PORT=18880
NODERED_CREDENTIAL_SECRET=change-me-local-only

INFLUX_BIND_ADDRESS=127.0.0.1
INFLUX_HOST_PORT=18086
INFLUXDB_ADMIN_USERNAME=smarthome
INFLUXDB_ADMIN_PASSWORD=change-me-influx-password
INFLUXDB_ADMIN_TOKEN=change-me-influx-token
INFLUXDB_ORG=smarthome
INFLUXDB_BUCKET=smarthome
INFLUXDB_BUCKET_RETENTION=365d

WEATHER_PROVIDER=open-meteo
WEATHER_LOCATION_LABEL=
WEATHER_LATITUDE=
WEATHER_LONGITUDE=
WEATHER_POLL_MINUTES=15
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1/forecast
